# Environment variables for OTC-P2P deployment and management.
# Copy this file to .env and fill in real values.
# Never commit .env or private keys.

# =============================================================================
# Signer
# =============================================================================
# Private key used by forge script. Use a key funded on the target network.
# PRIVATE_KEY may include or omit the 0x prefix.
PRIVATE_KEY=your_private_key_here

# =============================================================================
# RPC URLs
# =============================================================================
RPC_URL_SEPOLIA=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
RPC_URL_MAINNET=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
RPC_URL_POLYGON=https://polygon-rpc.com
RPC_URL_BSC=https://bsc-dataseed1.binance.org

# =============================================================================
# Block explorer API keys
# =============================================================================
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here

# =============================================================================
# Registry deployment
# =============================================================================
PROTOCOL_OWNER=0x0000000000000000000000000000000000000000
PROTOCOL_FEE_RECEIVER=0x0000000000000000000000000000000000000000

# Protocol fee share received by the registry for newly deployed factories.
# Values are basis points. 1000 = 10%, 2500 = 25%.
DEFAULT_DELIVERY_ONLY_PROTOCOL_FEE_SHARE_BPS=2500
DEFAULT_OTHER_PROTOCOL_FEE_SHARE_BPS=2500

# Full OTCClientVault is the default implementation.
# Set true to deploy OTCClientVaultLight and make the registry use it for future vault clones.
# When true, PROTOCOL_OWNER must be the PRIVATE_KEY signer because this calls an onlyOwner registry function.
USE_LIGHT_VAULT=false

# =============================================================================
# Operator factory deployment
# =============================================================================
# deployOperatorFactory in the registry requires msg.sender == OPERATOR_OWNER.
# If these differ, the registry contract will revert.
OPERATOR_OWNER=0x0000000000000000000000000000000000000000
OPERATOR_ADMIN=0x0000000000000000000000000000000000000000
OPERATOR_FEE_RECEIVER=0x0000000000000000000000000000000000000000

# Operator fee rates in basis points. Contract bounds are 5..10000.
TAKER_FEE_BPS=50
DELIVERY_FEE_BPS=50
OPEN_P2P_FEE_BPS=50

# =============================================================================
# Optional client vault deployment
# =============================================================================
# deploy-protocol-* deploys a first client vault only when DEPLOY_CLIENT_VAULT=true.
# deploy-vault-* always uses CLIENT_ADDRESS with FACTORY_ADDRESS.
DEPLOY_CLIENT_VAULT=false
CLIENT_ADDRESS=0x0000000000000000000000000000000000000000

# =============================================================================
# Existing deployment addresses for smaller scripts
# =============================================================================
REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# =============================================================================
# Manual verification
# =============================================================================
# forge script --verify is preferred during deployment. These are for standalone verify targets.
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
CONSTRUCTOR_ARGS=
